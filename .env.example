# ─── Telegram Bot ──────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ─── Google Gemini API ─────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ─── OpenAI API ────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here

# ─── Gemini TTS Voices ─────────────────────────────────────────────────────────
# Recipe voiceover voice (options: Kore, Charon, Fenrir, Aoede, Puck)
GEMINI_TTS_VOICE=Kore
# Paranormal channel voice — deep, mysterious (options: Charon, Fenrir, Kore)
PARANORMAL_TTS_VOICE=Charon

# ─── Authorized Users ──────────────────────────────────────────────────────────
# General bot access (comma-separated Telegram IDs)
# Use /id command in bot to get your ID
# Vlad=187993301  Igor=875313073
ALLOWED_TELEGRAM_IDS=187993301,875313073

# Feature: Recipe Voice — who can use "🎙️ Голос для рецептов"
# Leave empty to inherit ALLOWED_TELEGRAM_IDS
# Vlad=187993301  Igor=875313073
RECIPE_VOICE_ALLOWED_IDS=187993301,875313073

# Feature: Paranormal Channel — who can use "👻 Паранормальный канал" (@VoidWhispererX)
# Leave empty to inherit ALLOWED_TELEGRAM_IDS
# Vlad=187993301  Igor=875313073
VOIDWHISPERERX_ALLOWED_IDS=187993301,875313073

# ─── Google OAuth2 (for YouTube upload) ────────────────────────────────────────
# Get from Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
# Must have YouTube Data API v3 scope enabled
GOOGLE_CLIENT_ID=your_google_oauth_client_id_here
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret_here

# ─── VoidWhispererX YouTube Channel ───────────────────────────────────────────
# https://www.youtube.com/@VoidWhispererX
# Channel ID: found in YouTube Studio → Settings → Channel → Advanced settings
VOIDWHISPERERX_CHANNEL_ID=your_voidwhispererx_channel_id_here
# OAuth2 refresh token for the VoidWhispererX account
# Generate via: https://developers.google.com/oauthplayground
VOIDWHISPERERX_REFRESH_TOKEN=your_voidwhispererx_oauth_refresh_token_here
VOIDWHISPERERX_CHANNEL_URL=https://www.youtube.com/@VoidWhispererX
